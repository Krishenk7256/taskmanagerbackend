# development | staging | production
ENV=development

LOG_LEVEL=INFO

# PostgreSQL (asyncpg)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/dbname

# Лог SQL (только dev/staging)
SQL_ECHO=false

# Автосоздание таблиц при старте (не использовать в production — только Alembic)
AUTO_CREATE_TABLES=true

# Пул соединений
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# JWT: в production минимум 32 символа, не дефолтный placeholder
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS: через запятую или * для разработки
CORS_ORIGINS=*
